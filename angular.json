{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "wlc-engine": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "wlc-engine",
      "sourceRoot": "wlc-engine/src",
      "prefix": "wlc",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/wlc-engine/dist",
            "index": "wlc-engine/src/index.html",
            "main": "wlc-engine/src/main.ts",
            "polyfills": "wlc-engine/src/polyfills.ts",
            "tsConfig": "wlc-engine/tsconfig.app.json",
            "aot": true,
            "preserveSymlinks": true,
            "assets": [
              "wlc-engine/src/favicon.ico",
              "wlc-engine/src/assets"
            ],
            "styles": [
              "wlc-engine/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "wlc-engine/src/environments/environment.ts",
                  "with": "wlc-engine/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "wlc-engine:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "wlc-engine:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "wlc-engine:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "wlc-engine/src/test.ts",
            "polyfills": "wlc-engine/src/polyfills.ts",
            "tsConfig": "wlc-engine/tsconfig.spec.json",
            "karmaConfig": "wlc-engine/karma.conf.js",
            "assets": [
              "wlc-engine/src/favicon.ico",
              "wlc-engine/src/assets"
            ],
            "styles": [
              "wlc-engine/src/styles.scss"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "wlc-engine/tsconfig.app.json",
              "wlc-engine/tsconfig.spec.json",
              "wlc-engine/e2e/tsconfig.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        },
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "wlc-engine/e2e/protractor.conf.js",
            "devServerTarget": "wlc-engine:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "wlc-engine:serve:production"
            }
          }
        }
      }
    }},
  "cli": {
    "analytics": false
  },
  "defaultProject": "wlc-engine"
}
