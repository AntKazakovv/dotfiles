{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "wlc-engine": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "wlc-engine",
            "sourceRoot": "src",
            "prefix": "wlc",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:browser",
                    "options": {
                        "outputPath": "dist/",
                        "index": "src/index.html",
                        "main": "src/main.ts",
                        "polyfills": "src/polyfills.ts",
                        "tsConfig": "tsconfig.engine.json",
                        "aot": true,
                        "preserveSymlinks": true,
                        "assets": [
                            "src/favicon.ico",
                            "src/assets"
                        ],
                        "styles": [
                            "src/styles.scss"
                        ],
                        "scripts": [
                            "src/gettext.js"
                        ],
                        "stylePreprocessorOptions": {
                            "includePaths": [
                                "src",
                                "src/engine-scss/dummy"
                            ]
                        },
                        "allowedCommonJsDependencies": [
                            "@formatjs/intl-locale/polyfill",
                            "@formatjs/intl-numberformat/polyfill",
                            "@formatjs/intl-pluralrules/polyfill",
                            "css-element-queries",
                            "text-overflow-clamp",
                            "hosted-fields-sdk"
                        ],
                        "webWorkerTsConfig": "./tsconfig.worker.json"
                    },
                    "configurations": {
                        "production": {
                            "fileReplacements": [
                                {
                                    "replace": "src/system/environments/environment.ts",
                                    "with": "src/system/environments/environment.prod.ts"
                                },
                                {
                                    "replace": "src/modules/core/system/interceptors/interceptors.ts",
                                    "with": "src/modules/core/system/interceptors/interceptors.prod.ts"
                                }
                            ],
                            "optimization": true,
                            "outputHashing": "all",
                            "sourceMap": false,
                            "extractCss": true,
                            "namedChunks": false,
                            "extractLicenses": true,
                            "vendorChunk": false,
                            "aot": true,
                            "budgets": [
                                {
                                    "type": "bundle",
                                    "name": "main",
                                    "maximumWarning": "2.5mb",
                                    "maximumError": "3.5mb"
                                },
                                {
                                    "type": "initial",
                                    "maximumWarning": "2mb",
                                    "maximumError": "5mb"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "100kb",
                                    "maximumError": "100kb"
                                }
                            ]
                        }
                    }
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "options": {
                        "browserTarget": "wlc-engine:build"
                    },
                    "configurations": {
                        "production": {
                            "browserTarget": "wlc-engine:build:production"
                        }
                    }
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n",
                    "options": {
                        "browserTarget": "wlc-engine:build"
                    }
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "main": "./src/test.ts",
                        "polyfills": "src/polyfills.ts",
                        "tsConfig": "./tsconfig.spec.json",
                        "karmaConfig": "./karma.conf.js",
                        "assets": [
                            "src/favicon.ico",
                            "src/assets"
                        ],
                        "styles": [
                            "src/styles.scss"
                        ],
                        "stylePreprocessorOptions": {
                            "includePaths": [
                                "src",
                                "src/engine-scss/dummy"
                            ]
                        },
                        "scripts": [
                            "./src/gettext.js"
                        ],
                        "webWorkerTsConfig": "tsconfig.worker.json"
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "options": {
                        "eslintConfig": ".eslintrc.js",
                        "lintFilePatterns": [
                            "src/**/*.ts"
                        ]
                    }
                },
                "e2e": {
                    "builder": "@angular-devkit/build-angular:protractor",
                    "options": {
                        "protractorConfig": "wlc-engine/e2e/protractor.conf.js",
                        "devServerTarget": "wlc-engine:serve"
                    },
                    "configurations": {
                        "production": {
                            "devServerTarget": "wlc-engine:serve:production"
                        }
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": false
    },
    "defaultProject": "wlc-engine"
}
