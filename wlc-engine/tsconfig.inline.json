{
    "compilerOptions": {
        "outDir": "./roots/static/dist/",
        "sourceMap": true,
        "strict": true,
        "noImplicitReturns": true,
        "noImplicitAny": true,
        "module": "es6",
        "moduleResolution": "node",
        "target": "es2015",
        "allowJs": true
    },
    "lib": [
        "es2015"
    ],
    "include": [
        "./src/inline/**/*"
    ]
}
