{
    "compilerOptions": {
        "baseUrl": ".",
        "outDir": "./roots/static/dist/",
        "alwaysStrict": true,
        "experimentalDecorators": true,
        "jsx": "react",
        "module": "commonjs",
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noUnusedLocals": true,
        "pretty": true,
        "removeComments": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strictNullChecks": true,
        "target": "es5",
    },
    "lib": [
        "es2015"
    ],
    "include": [
        "./src/inline/**/*",
        "./src/interfaces/global.interface.ts",
        "./node_modules/@sentry/**/*"
    ]
}
