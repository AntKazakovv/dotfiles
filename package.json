{
  "name": "wlcengine",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "build-locale:en": "ng build --prod --i18n-locale en --i18n-format xlf --i18n-file translate/messages.en.xlf --output-path=dist/en --baseHref /en/",
    "build-locale:es": "ng build --prod --i18n-locale es --i18n-format xlf --i18n-file translate/messages.es.xlf --output-path=dist/es --baseHref /es/",
    "build-locale:hi": "ng build --prod --i18n-locale hi --i18n-format xlf --i18n-file translate/messages.hi.xlf --output-path=dist/hi --baseHref /hi/",
    "build-locale": "npm run build-locale:en && npm run build-locale:es && npm run build-locale:hi",
    "stylelint": "stylelint './src/styles/_theme.scss' --syntax scss --config .stylelintrc",
    "pre-commit": "npm run stylelint && npm run build",
    "postinstall": "./githooks/add-symlinks.sh"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~9.0.6",
    "@angular/cdk": "^9.1.2",
    "@angular/common": "~9.0.6",
    "@angular/compiler": "~9.0.6",
    "@angular/core": "~9.0.6",
    "@angular/forms": "~9.0.6",
    "@angular/localize": "~9.1.0-next.4",
    "@angular/material": "^9.1.2",
    "@angular/platform-browser": "~9.0.6",
    "@angular/platform-browser-dynamic": "~9.0.6",
    "@angular/router": "~9.0.6",
    "rxjs": "^6.5.2",
    "tslib": "^1.10.0",
    "zone.js": "~0.10.2",
    "@ngx-translate/core": "^11.0.1",
    "@ngx-translate/http-loader": "^4.0.0",
    "@uirouter/angular": "^6.0.1",
    "@uirouter/core": "^6.0.1",
    "@uirouter/rx": "^0.6.4",
    "@uirouter/visualizer": "^7.0.0",
    "lodash": "^4.17.15",
    "moment": "^2.24.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.901.0-next.3",
    "@angular/cli": "~9.1.0-next.3",
    "@angular/compiler-cli": "~9.0.6",
    "@angular/language-service": "~9.0.6",
    "@types/jasmine": "~3.3.8",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^12.11.1",
    "codelyzer": "^5.1.2",
    "jasmine": "^3.5.0",
    "jasmine-core": "~3.4.0",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "~4.1.0",
    "karma-chrome-launcher": "~2.2.0",
    "karma-coverage-istanbul-reporter": "~2.0.1",
    "karma-jasmine": "~2.0.1",
    "karma-jasmine-html-reporter": "^1.4.0",
    "protractor": "~5.4.0",
    "stylelint": "^13.2.1",
    "ts-node": "~7.0.0",
    "tslint": "~5.15.0",
    "typescript": "<=3.8.0"
  }
}
