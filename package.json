{
    "name": "@egamings/wlc-engine",
    "version": "0.2.11",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "docs": "npm run build:docs -- --serve",
        "build:docs": "compodoc -p ./tsconfig.docs.json -d docs/compodoc",
        "build:sassdocs": "npm run gulp sassdoc",
        "dist": "git submodule update --init && ng build --project wlc-engine --prod && npm run build:docs && npm run build:sassdocs",
        "test": "ng test",
        "lint": "ng lint",
        "e2e": "ng e2e",
        "update-locale": "ngx-translate-extract -i ./src/**/*.{ts,tsx,html} -o src/system/languages/messages.pot --sort --format pot && node ./utils/pot2po.js",
        "gulp": "gulp",
        "update": "ng update @angular/cli @angular/core --force",
        "fullup": "rm -rf node_modules package-lock.json && npm install"
    },
    "private": true,
    "dependencies": {
        "@angular-builders/custom-webpack": "11.0.0",
        "@angular-devkit/build-angular": "0.1101.1",
