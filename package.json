{
    "name": "@egamings/wlc-engine",
    "version": "0.0.48",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "docs": "npm run build:docs -- --serve",
        "build:docs": "compodoc -p ./tsconfig.docs.json -d docs",
        "dist": "git submodule update --init && ng build --project wlc-engine --prod && npm run build:docs",
        "test": "ng test",
        "lint": "ng lint",
        "e2e": "ng e2e",
        "update-locale": "ngx-translate-extract -i ./wlc-engine/src/**/*.{ts,tsx,html} -o ./wlc-engine/src/languages/messages.pot --sort --format pot && node ./wlc-engine/utils/pot2po.js && rm -rf ./wlc-engine/src/languages/messages.pot",
        "gulp": "gulp",
        "update": "ng update @angular/cli @angular/core --force",
        "fullup": "rm -rf node_modules package-lock.json && npm install"
    },
    "private": true,
    "dependencies": {
        "@angular-builders/custom-webpack": "10.0.1",
        "@angular-devkit/build-angular": "~0.1000.2",
        "@angular-eslint/builder": "0.5.0-beta.5",
        "@angular-eslint/eslint-plugin": "0.5.0-beta.5",
        "@angular-eslint/eslint-plugin-template": "0.5.0-beta.5",
        "@angular-eslint/schematics": "0.5.0-beta.5",
        "@angular-eslint/template-parser": "0.5.0-beta.5",
        "@angular/animations": "~10.1.0",
        "@angular/cli": "~10.0.2",
        "@angular/common": "~10.0.3",
        "@angular/compiler": "~10.0.3",
        "@angular/compiler-cli": "~10.0.3",
        "@angular/core": "~10.0.3",
        "@angular/forms": "~10.0.3",
        "@angular/language-service": "~10.0.3",
        "@angular/platform-browser": "~10.1.0",
        "@angular/platform-browser-dynamic": "~10.0.3",
        "@angular/platform-server": "~10.0.3",
        "@angular/router": "~10.0.3",
        "@angular/service-worker": "^10.0.3",
        "@biesbjerg/ngx-translate-extract": "^6.1.0",
        "@nguniversal/builders": "^9.1.1",
        "@nguniversal/express-engine": "^9.1.1",
        "@ngx-translate/core": "^12.1.2",
        "@ngx-translate/http-loader": "^4.0.0",
        "@types/express": "^4.17.7",
        "@types/jasmine": "~3.5.11",
        "@types/jasminewd2": "~2.0.8",
        "@types/jsdom": "^16.2.3",
        "@types/lodash": "^4.14.157",
        "@types/luxon": "^1.25.0",
        "@types/node": "^12.19.2",
        "@typescript-eslint/eslint-plugin": "4.5.0",
        "@typescript-eslint/parser": "4.5.0",
        "@uirouter/angular": "^6.0.3",
        "@uirouter/core": "^6.0.5",
        "@uirouter/rx": "^0.6.5",
        "angular-resize-event": "^2.0.1",
        "bootstrap": "^5.0.0-alpha1",
        "clean-webpack-plugin": "^3.0.0",
        "concurrently": "^5.2.0",
        "create-file": "^1.0.1",
        "eslint": "7.12.0",
        "eslint-webpack-plugin": "2.1.0",
        "express": "^4.17.1",
        "glob": "^7.1.6",
        "gulp": "^4.0.2",
        "gulp-angular-gettext": "^2.3.0",
        "gulp-if": "^3.0.0",
        "gulp-json-editor": "^2.5.4",
        "gulp-livereload": "^4.0.2",
        "gulp-rename": "^2.0.0",
        "gulp-shell": "^0.8.0",
        "gulp-stylelint": "^13.0.0",
        "html-webpack-plugin": "^4.3.0",
        "jasmine-core": "~3.5.0",
        "jasmine-spec-reporter": "~4.2.1",
        "karma": "~4.3.0",
        "karma-chrome-launcher": "^3.1.0",
        "karma-coverage-istanbul-reporter": "~2.1.1",
        "karma-jasmine": "~2.0.1",
        "karma-jasmine-html-reporter": "^1.5.4",
        "lodash": "^4.17.19",
        "luxon": "^1.25.0",
        "make-dir": "^3.1.0",
        "ngx-swiper-wrapper": "^10.0.0",
        "parse5": "^6.0.0",
        "popper.js": "^1.16.1",
        "protractor": "~5.4.4",
        "reset-css": "^5.0.1",
        "rxjs": "~6.5.5",
        "stream-combiner2": "^1.1.1",
        "stylelint": "^13.7.2",
        "swiper": "^6.3.4",
        "through2": "^3.0.2",
        "tmp": "^0.2.1",
        "ts-loader": "^7.0.5",
        "ts-node": "~8.3.0",
        "tslib": "^1.13.0",
        "typescript": "~3.9.6",
        "webpack-stream": "^5.2.1",
        "zone.js": "~0.10.3"
    },
