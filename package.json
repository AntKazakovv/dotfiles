{
    "name": "@egamings/wlc-engine",
    "version": "1.3.76-rc.6",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "dev:docs": "compodoc --serve --port=4201 --watch",
        "build:docs": "compodoc --silent",
        "build:sassdocs": "npm run gulp sassdoc",
        "dist": "git submodule update --init && ng build --project wlc-engine --configuration production && npm run build:docs && npm run build:sassdocs",
        "test": "CHROMIUM_BIN=chromium ng test",
        "lint": "lint-staged",
        "eslint": "ng lint",
        "stylelint": "stylelint \"./**/*.scss\" --config='./stylelint.config.js'",
        "e2e": "ng e2e",
        "update-locale": "ngx-translate-extract -i ./src/**/*.{ts,tsx,html} -o src/system/languages/messages.pot --sort --format pot && node ./utils/pot2po.js",
        "gulp": "gulp",
        "update": "ng update @angular/cli @angular/core --force",
        "test:api": "cd api-tests && PROJECT_URL=\"https://qa-devcasino.egamings.com\" npx jasmine-ts --config=jasmine.json",
        "fullup": "git submodule update --init && rm -rf node_modules package-lock.json && npm install"
    },
    "lint-staged": {
        "src/**/*.ts": "eslint",
        "src/**/*.scss": "stylelint"
    },
    "private": true,
