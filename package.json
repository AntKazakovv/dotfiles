{
    "name": "@egamings/wlc-engine",
    "version": "1.76.0-rc.2",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "dev:docs": "compodoc --serve --port=4201 --watch",
        "build:docs": "compodoc --silent",
        "build:sassdocs": "npm run gulp sassdoc",
        "dist": "ng build --project wlc-engine --configuration production && npm run build:docs && npm run build:sassdocs",
        "test": "CHROMIUM_BIN=chromium ng test",
        "lint": "lint-staged",
        "eslint": "ng lint",
        "stylelint": "stylelint \"./**/*.scss\" --config='./stylelint.config.js'",
        "e2e": "ng e2e",
        "checking-changes": "gulp checking-changes",
        "update-locale": "ngx-translate-extract -i ./src/**/*.{ts,tsx,html} -o node_modules/@egamings/wlc-engine-translate/messages.pot --sort --format pot && node ./utils/pot2po.js",
        "gulp": "gulp",
        "update": "ng update @angular/cli @angular/core --force",
        "test:api": "cd api-tests && npx jasmine-ts --config=jasmine.json",
        "fullup": "rm -rf node_modules package-lock.json && npm install",
        "prepare": "npx gulp fix-jasmine"
    },
    "lint-staged": {
        "src/**/*.ts": "eslint",
        "src/**/*.scss": "stylelint"
    },
    "engines": {
        "node": "18.x || 20.x",
        "npm": "8.x || 9.x || 10.x"
    },
