{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "paths": {
            "wlc-engine/*": [
                "./src/*"
            ],
            "wlc-config/*": [
                "./wlc-src/config/frontend/*"
            ],
            "wlc-svg/*": [
                "./wlc-src/svg/*"
            ]
        }
    },
    "files": [
        "src/main.ts",
        "src/polyfills.ts",
        "src/typings.d.ts"
    ],
    "include": [
        "wlc-engine/**/*.d.ts"
    ]
}
