{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": [
      "jasmine",
      "node",
      "karma-viewport"
    ],
    "paths": {
      "wlc-engine/*": [
          "./src/*"
      ],
      "wlc-config/*": [
          "./wlc-src/config/frontend/*"
      ],
      "wlc-svg/*": [
          "./wlc-src/svg/*"
      ]
    }
  },
  "files": [
    "src/test.ts",
    "src/polyfills.ts"
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
