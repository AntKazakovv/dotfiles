{
    "file": "/angular.json",
    "data": {
        "projects.wlc-site.architect.build.options": {
            "customWebpackConfig": {
                "path": "./wlc-engine/system/webpack-config/webpack.app.js",
                "mergeStrategies": {
                    "externals": "append"
                }
            },
            "allowedCommonJsDependencies": [
                "@formatjs/intl-locale/polyfill",
                "@formatjs/intl-numberformat/polyfill",
                "@formatjs/intl-numberformat/should-polyfill",
                "@formatjs/intl-pluralrules/polyfill",
                "@formatjs/intl-pluralrules/should-polyfill",
                "css-element-queries",
                "text-overflow-clamp",
                "hosted-fields-sdk",
                "@sumsub/websdk"
            ],
            "outputPath": "roots/static/dist",
            "baseHref": "/",
            "deployUrl": "/static/dist/",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": "src/polyfills.ts",
            "tsConfig": "tsconfig.app.json",
            "preserveSymlinks": true,
            "aot": false,
            "verbose": false,
            "assets": [
                "src/favicon.ico",
                "src/assets",
                "src/manifest.webmanifest"
            ],
            "styles": [
                "wlc-engine/engine-scss/engine.styles.scss"
            ],
            "stylePreprocessorOptions": {
                "includePaths": [
                    "./src/app-styles",
                    "./wlc-engine"
                ]
            },
            "scripts": [
                "wlc-engine/gettext.js"
            ],
            "webWorkerTsConfig": "./tsconfig.worker.json"
        },
        "projects.wlc-site.architect.build.configurations.dev": {
            "watch": true,
            "buildOptimizer": false,
            "optimization": false,
            "vendorChunk": true,
            "extractLicenses": false,
            "sourceMap": true,
            "namedChunks": true
        },
        "projects.wlc-site.architect.build.configurations.production": {
            "fileReplacements": [
                {
                    "replace": "wlc-engine/system/environments/environment.ts",
                    "with": "wlc-engine/system/environments/environment.prod.ts"
                },
                {
                    "replace": "wlc-engine/modules/core/system/interceptors/interceptors.ts",
                    "with": "wlc-engine/modules/core/system/interceptors/interceptors.prod.ts"
                }
            ],
            "optimization": true,
            "buildOptimizer": false,
            "outputHashing": "all",
            "sourceMap": false,
            "namedChunks": false,
            "extractLicenses": true,
            "vendorChunk": false,
            "aot": false,
            "budgets": [
                {
                    "type": "bundle",
                    "name": "main",
                    "maximumWarning": "2.5mb",
                    "maximumError": "3.5mb"
                },
                {
                    "type": "initial",
                    "maximumWarning": "2mb",
                    "maximumError": "5mb"
                },
                {
                    "type": "anyComponentStyle",
                    "maximumWarning": "30kb",
                    "maximumError": "100kb"
                }
            ],
            "serviceWorker": true,
            "ngswConfigPath": "./ngsw-config.json",
            "watch": false
        },
        "projects.wlc-site.architect.serve.options": {
            "baseHref": "/"
        }
    }
}
